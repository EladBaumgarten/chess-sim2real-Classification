.DS_Store
Thumbs.db
*.swp
*.log
*.err
*.out

# ---- trained model weights (8GB+ of checkpoints; some >100MB GitHub limit) ----
# Regenerable by training; not needed for the code submission. We commit ONLY
# the single checkpoint predict_board() loads (negated below).
*.pt
*.pth
*.ckpt
*.safetensors
*.onnx

# ---- KEEP each dino run's best_real.pt (negate the *.pt ignore above) ----
# evaluation/predict_board.py loads dino_combined_Game6boosted/best_real.pt;
# the other runs' best_real.pt are committed for reference/comparison.
!checkpoints/*/best_real.pt
# dino_zeroshot is synth-only (no best_real.pt) — keep its synth-monitor checkpoint instead
!checkpoints/dino_zeroshot/best_synth_monitor.pt

# ---- diagnostic/report-figure scripts: kept locally, not part of the submission ----
analysis/

# ---- syn_data_generation: only dataset_v1 code is tracked ----
# v1.5 / v2 generation code is collected into these folders, kept locally only.
syn_data_generation/dataset_v1.5/
syn_data_generation/dataset_v2/
syn_data_generation/audit_dataset_v1_grid_dumps.txt
syn_data_generation/audit_report.txt
syn_data_generation/chess-sets

# ---- preprocessing: only the core dataset_v1 pipeline is tracked ----
preprocessing/game7_orientation_diagnostics.py
preprocessing/train_zero_shot.py

# ---- results: regenerable diagnostic outputs (figures, metrics, report writeup) — kept local only ----
results/

# ---- training/convnext & training/resnet18: kept local only (not tracked) ----
training/convnext/
training/resnet18/

# ---- training/dino: track only the training code files + README (everything else local) ----
training/dino/*
!training/dino/README.md
!training/dino/train.py
!training/dino/train_combindedGame6_diag.py
!training/dino/train_realonly_ablation.py
!training/dino/train_labelsmooth_ablation.py

# local report material (not part of the repo)
report_bundle/
report_bundle2/

# report figures (build artifacts, not source)
report_plots/

# ---- final submission document (kept local, not tracked) ----
Projects Final Submission  (1).pdf

# ---- report / presentation working files (kept local) ----
